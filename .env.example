# MedDevice DMS - Environment Variables
# Copy to .env and fill in your values

# SurrealDB
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=meddevice
SURREAL_DB=dms

# App
# SECRET_KEY must be exactly 64 hexadecimal characters (openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-64-hex-secret-key
UTILS_SECRET=change-me-to-another-random-64-hex-secret-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=123456789
WEBHOOK_URL=https://your-tunnel-url.com

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Outline Wiki
OUTLINE_API_URL=http://outline:3000/api
OUTLINE_API_TOKEN=your_outline_token

# Storage
STORAGE_BASE_PATH=./storage/files
